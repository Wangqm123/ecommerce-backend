# Server
PORT=3000
NODE_ENV=development

# MySQL（本地使用 DB_HOST 等）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=ecommerce_analysis
DB_CONNECTION_LIMIT=10

# 或者使用 Railway 提供的 DATABASE_URL（会覆盖以上）
DATABASE_URL=mysql://user:password@host:port/db_name

# Upload
UPLOAD_MAX_SIZE=52428800
UPLOAD_DIR=./uploads

# CORS：多个来源用逗号分隔，例如 http://localhost:5173,https://frontend.up.railway.app
CORS_ORIGIN=http://localhost:5173